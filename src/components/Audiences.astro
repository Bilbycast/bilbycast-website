---
const primary = [
  {
    title: 'Broadcast facility & integrators',
    pain: 'You bridge SDI / SMPTE 2110 with internet protocols inside an NMOS plant — and need one screen to drive it.',
    moves: [
      'NMOS IS-04 / 05 / 08 + BCP-004; SMPTE ST 2110-20/-23/-30/-31/-40 + PTP + 2022-7',
      'AI-assisted flow creation, real-time topology, multi-tenant Groups',
      'Driver-aware control of Bilbycast and third-party broadcast devices',
    ],
    href: '/features/manager/',
    cta: 'See the management stack',
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>`,
    accent: 'sky',
  },
  {
    title: 'OTT & live distribution',
    pain: 'You need to land contribution feeds and fan them out to viewers in every format.',
    moves: [
      'Ingest SRT / RIST / RTMP / WebRTC, fan out to HLS / CMAF-LL / WebRTC',
      'In-process H.264 / HEVC / NVENC video and AAC / Opus / MP2 / AC-3 audio',
      'Hot input switching with zero-gap PMT bump — no glitch on failover',
    ],
    href: '/features/one-gateway/',
    cta: 'See the protocol gateway',
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /></svg>`,
    accent: 'sky',
  },
];

const secondary = [
  {
    title: 'Live sports & remote production',
    pain: 'JKL-scrub Replay, sport-preset tag profiles, push-to-air, PGM/PVW Switcher, cron Routines.',
    href: '/features/live-sports/',
    cta: 'Replay & Switcher',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" /></svg>`,
  },
  {
    title: 'Multi-vendor broadcast plant',
    pain: 'One UI for Bilbycast edges, third-party encoders, and Appear X gateways. Driver-aware action system extends.',
    href: '/features/manager/',
    cta: 'Driver-aware control',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" /></svg>`,
  },
];
---

<section id="audiences" class="py-24 lg:py-32 bg-slate-900/30">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Who it's for</h2>
      <p class="mt-4 text-lg text-slate-400">
        Two flagship audiences, two follow-ons. Pick the one that matches your day.
      </p>
    </div>

    <!-- Primary audiences (large cards) -->
    <div class="mt-16 grid gap-6 lg:grid-cols-2">
      {primary.map((a) => (
        <a
          href={a.href}
          class="group flex flex-col rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-800/40 to-slate-900/20 p-8 transition hover:border-sky-800/60 hover:shadow-xl hover:shadow-sky-950/20 no-underline"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-950 text-sky-400 ring-1 ring-sky-800/40">
            <Fragment set:html={a.icon} />
          </div>
          <h3 class="mt-5 text-xl font-bold text-white">{a.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{a.pain}</p>
          <ul class="mt-5 space-y-2.5">
            {a.moves.map((m) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-300">
                <svg class="mt-0.5 h-4 w-4 flex-none text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{m}</span>
              </li>
            ))}
          </ul>
          <span class="mt-auto pt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-sky-400 group-hover:gap-2 transition-all">
            {a.cta}
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </span>
        </a>
      ))}
    </div>

    <!-- Secondary audiences (smaller cards) -->
    <div class="mt-6 grid gap-6 lg:grid-cols-2">
      {secondary.map((a) => (
        <a
          href={a.href}
          class="group flex items-center gap-5 rounded-xl border border-slate-800 bg-slate-900/40 p-5 transition hover:border-slate-700 no-underline"
        >
          <div class="flex h-10 w-10 flex-none items-center justify-center rounded-lg bg-slate-800 text-slate-300 ring-1 ring-slate-700">
            <Fragment set:html={a.icon} />
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-semibold text-white">{a.title}</div>
            <div class="text-xs text-slate-500">{a.pain}</div>
          </div>
          <span class="hidden text-xs font-medium text-slate-400 sm:inline-flex sm:items-center sm:gap-1 group-hover:text-sky-400">
            {a.cta}
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
