---
import { Image } from 'astro:assets';
import logo from '../assets/bilbycast-icon.png';
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800/60 bg-[#020617]/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-2.5 text-white no-underline">
      <Image src={logo} alt="Bilbycast" width={32} height={32} class="rounded" />
      <span class="text-lg font-bold tracking-tight">Bilbycast</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      <a href="/features/" class="text-sm text-slate-400 transition hover:text-white">Features</a>
      <a href="/use-cases/" class="text-sm text-slate-400 transition hover:text-white">Use cases</a>
      <a href="/pricing/" class="text-sm text-slate-400 transition hover:text-white">Pricing</a>
      <a href="/services/" class="text-sm text-slate-400 transition hover:text-white">Services</a>
      <a href="/getting-started/" class="text-sm text-slate-400 transition hover:text-white">Docs</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/Bilbycast"
        class="hidden items-center gap-1.5 text-sm text-slate-400 transition hover:text-white sm:inline-flex"
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span class="hidden lg:inline">GitHub</span>
      </a>
      <a
        href="/getting-started/"
        class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-500"
      >
        Get Started
      </a>
    </div>
  </div>
</header>
