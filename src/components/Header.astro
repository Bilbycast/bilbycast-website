---
import { Image } from 'astro:assets';
import logo from '../assets/bilbycast-icon.png';
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800/60 bg-[#020617]/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-2.5 text-white no-underline">
      <Image src={logo} alt="Bilbycast" width={32} height={32} class="rounded" />
      <span class="text-lg font-bold tracking-tight">Bilbycast</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      <a href="#features" class="text-sm text-slate-400 transition hover:text-white">Features</a>
      <a href="#protocols" class="text-sm text-slate-400 transition hover:text-white">Protocols</a>
      <a href="#products" class="text-sm text-slate-400 transition hover:text-white">Products</a>
      <a href="#screenshots" class="text-sm text-slate-400 transition hover:text-white">Screenshots</a>
      <a href="/getting-started/" class="text-sm text-slate-400 transition hover:text-white">Docs</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/Bilbycast"
        class="hidden text-sm text-slate-400 transition hover:text-white sm:block"
        target="_blank"
        rel="noopener"
      >
        GitHub
      </a>
      <a
        href="/getting-started/"
        class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-500"
      >
        Get Started
      </a>
    </div>
  </div>
</header>
