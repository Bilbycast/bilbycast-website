---
import { Image } from 'astro:assets';
import dashboard from '../assets/screenshots/dashboard.png';
---

<section class="relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-28">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-b from-sky-950/30 via-[#020617] to-[#020617]"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] rounded-full bg-sky-600/8 blur-[120px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-sky-800/40 bg-sky-950/40 px-4 py-1.5 text-xs font-medium text-sky-300">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-sky-400 opacity-60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-sky-400"></span>
        </span>
        Live media transport · Open-source core
      </div>

      <!-- Headline -->
      <h1 class="mx-auto max-w-4xl text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
        Get the picture there
        <span class="block bg-gradient-to-r from-sky-400 to-cyan-300 bg-clip-text text-transparent">
          over any link, in any format.
        </span>
      </h1>

      <!-- Subheadline -->
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-400 sm:text-xl">
        Bilbycast unifies SRT, RIST, RTMP, HLS, WebRTC, and SMPTE ST 2110 under one AI-assisted control plane &mdash;
        with in-process transcoding and driver-aware control that extends to third-party broadcast devices. The
        transcode box, the NMOS gateway, the protocol bridge, and the dashboard for it all &mdash; collapsed into
        one Rust suite.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/getting-started/"
          class="inline-flex items-center gap-2 rounded-xl bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-600/20 transition hover:bg-sky-500 hover:shadow-sky-500/30"
        >
          Try it in 10 minutes
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="#showcase"
          class="inline-flex items-center gap-2 rounded-xl border border-slate-700 bg-slate-800/50 px-6 py-3 text-sm font-semibold text-slate-300 transition hover:border-slate-600 hover:bg-slate-800 hover:text-white"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z" />
          </svg>
          See it in action
        </a>
      </div>
    </div>

    <!-- Hero Screenshot -->
    <div class="relative mx-auto mt-16 max-w-5xl">
      <!-- Glow behind screenshot -->
      <div class="absolute -inset-4 rounded-2xl bg-gradient-to-r from-sky-600/10 via-cyan-500/10 to-sky-600/10 blur-2xl"></div>

      <!-- Browser chrome frame -->
      <div class="relative overflow-hidden rounded-xl border border-slate-700/50 bg-slate-900 shadow-2xl shadow-black/50">
        <!-- Browser bar -->
        <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-2.5">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-slate-600"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-slate-600"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-slate-600"></div>
          </div>
          <div class="ml-3 flex-1 rounded-md bg-slate-700/50 px-3 py-1 text-xs text-slate-500">
            manager.bilbycast.com
          </div>
        </div>
        <!-- Screenshot -->
        <Image
          src={dashboard}
          alt="Bilbycast Manager Dashboard showing 7 managed edge nodes and relay server"
          class="w-full h-auto"
          widths={[640, 960, 1280]}
          sizes="(max-width: 640px) 640px, (max-width: 960px) 960px, 1280px"
        />
      </div>
    </div>
  </div>
</section>
