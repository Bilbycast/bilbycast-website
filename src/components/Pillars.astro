---
import { Image } from 'astro:assets';
import topologyImg from '../assets/screenshots/network-topology.png';
import flowsImg from '../assets/screenshots/flows.png';
import edgeStatusImg from '../assets/screenshots/edge-status.png';
import aiConfigImg from '../assets/screenshots/ai-config.png';

const pillars = [
  {
    eyebrow: 'For everyone running this',
    title: 'Manage your whole media plant from one screen.',
    body: 'Real-time topology, per-flow stats, live thumbnails, AI-assisted flow creation, driver-aware control of third-party broadcast devices. Multi-tenant Groups with brand theming, OIDC SSO, MFA, encrypted backup, envelope-encrypted secrets at rest.',
    bullets: [
      'AI flow assistant — OpenAI, Anthropic, or Gemini, credentials stripped before context',
      'Driver-aware action system — Bilbycast and Appear X today, vendor SDK published',
      'Multi-tenant Groups with brand theming, OIDC SSO, MFA, encrypted backup',
    ],
    href: '/features/manager/',
    image: topologyImg,
    alt: 'Bilbycast Manager network topology view',
  },
  {
    eyebrow: 'For OTT, distribution, facilities',
    title: 'One gateway, every format.',
    body: 'Twelve protocols ingressed and egressed in a single Rust binary. In-process video transcoding (H.264 / HEVC / NVENC) and audio transcoding (AAC / Opus / MP2 / AC-3) — no ffmpeg subprocess, no separate transcode box. NMOS-friendly out of the box.',
    bullets: [
      'SRT, RIST, RTP, RTMP, HLS, CMAF-LL, WebRTC, ST 2110-20/-23/-30/-31/-40',
      'Hot input switching with zero-gap PMT bump — no black on failover',
      'In-process transcode for both video and audio, end-to-end encrypted on the wire',
    ],
    href: '/features/one-gateway/',
    image: flowsImg,
    alt: 'Bilbycast Manager flows view with live thumbnails and protocol badges',
  },
  {
    eyebrow: 'For live sports, event production',
    title: 'Built for live sports.',
    body: 'JKL-scrub Replay with mark in/out, customisable per-sport tag profiles, push-to-air per clip, and a PGM/PVW Switcher for the director. Cron-scheduled Routines automate the show-day workflow with DST-correct timezones.',
    bullets: [
      'Per-flow Replay with lock-to-live and ± 100 ms bracket-trim',
      'Sport-preset catalog: Soccer, Rugby, NFL, AFL, Cricket, Tennis, Hockey, Basketball, Volleyball, Baseball, and more',
      'Live Switcher (PGM/PVW), Routines (cron + AI), Multi-tenant Groups',
    ],
    href: '/features/live-sports/',
    image: edgeStatusImg,
    alt: 'Bilbycast edge node detail view with live transport analysis',
  },
  {
    eyebrow: 'For broadcast facility integrators',
    title: 'Drops into your broadcast facility.',
    body: 'NMOS IS-04 / IS-05 / IS-08 discovery, connection management, and audio channel mapping. Full SMPTE ST 2110-20 / -23 / -30 / -31 / -40 with PTP, 2022-7 Red/Blue, and BCP-004 receiver capability sets. Speaks the standards your control system already speaks.',
    bullets: [
      'NMOS IS-04 / 05 / 08 + BCP-004 — registered, controlled, and audio-mapped natively',
      'SMPTE ST 2110-20 / -23 / -30 / -31 / -40 + PTP + 2022-7 Red/Blue',
      'SMPTE 2022-1 FEC, TR-101290 transport-stream analysis, RIST TR-06-1 / TR-07',
    ],
    href: '/features/one-gateway/#standards',
    image: aiConfigImg,
    alt: 'Bilbycast Manager AI-assistant configuration page',
  },
];
---

<section id="pillars" class="py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Four things Bilbycast does that nobody else puts in one box.
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        Pick the pillar that matches your job. Each links through to a deeper page with diagrams and screenshots.
      </p>
    </div>

    <div class="mt-20 space-y-24 lg:space-y-32">
      {pillars.map((p, i) => (
        <div class={`flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-16 ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <!-- Image -->
          <div class="lg:w-3/5">
            <div class="relative">
              <div class="absolute -inset-2 rounded-2xl bg-gradient-to-r from-sky-600/10 via-cyan-500/10 to-sky-600/10 blur-xl"></div>
              <div class="relative overflow-hidden rounded-xl border border-slate-700/50 bg-slate-900 shadow-xl shadow-black/30">
                <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-2">
                  <div class="flex gap-1.5">
                    <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                    <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                    <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                  </div>
                </div>
                <Image
                  src={p.image}
                  alt={p.alt}
                  class="w-full h-auto"
                  widths={[480, 720, 960]}
                  sizes="(max-width: 768px) 480px, (max-width: 1024px) 720px, 960px"
                />
              </div>
            </div>
          </div>

          <!-- Text -->
          <div class="lg:w-2/5">
            <div class="text-xs font-semibold uppercase tracking-wider text-sky-400">{p.eyebrow}</div>
            <h3 class="mt-3 text-2xl font-bold tracking-tight text-white sm:text-3xl">{p.title}</h3>
            <p class="mt-4 text-base leading-relaxed text-slate-400">{p.body}</p>
            <ul class="mt-6 list-none space-y-2.5">
              {p.bullets.map((b) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-300">
                  <svg class="mt-0.5 h-4 w-4 flex-none text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <a
              href={p.href}
              class="group mt-8 inline-flex items-center gap-1.5 text-sm font-semibold text-sky-400 transition hover:text-sky-300"
            >
              See how it works
              <svg class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-20 text-center">
      <a
        href="/features/all/"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-400 transition hover:text-white"
      >
        Looking for the full feature matrix? See every capability
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
