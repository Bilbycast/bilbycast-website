---
const products = [
  {
    name: 'bilbycast-edge',
    description: 'Media transport gateway bridging SRT, RTP, UDP, RTMP, RTSP, HLS, WebRTC, and SMPTE ST 2110-30/-31/-40 with FEC, hitless redundancy, and TCP/UDP port forwarding over encrypted QUIC tunnels.',
    link: '/edge/overview/',
    color: 'sky',
  },
  {
    name: 'bilbycast-manager',
    description: 'Web-based management UI and API with real-time topology visualization, AI-assisted flow configuration, and a driver-aware action system that extends to third-party broadcast devices.',
    link: '/manager/overview/',
    color: 'violet',
  },
  {
    name: 'bilbycast-relay',
    description: 'Stateless QUIC relay enabling IP tunneling between NAT\'d edge nodes with end-to-end ChaCha20-Poly1305 encryption and per-tunnel HMAC bind tokens.',
    link: '/relay/overview/',
    color: 'emerald',
  },
  {
    name: 'bilbycast-srt',
    description: 'Pure Rust SRT protocol implementation — wire-compatible with libsrt v1.5.5. AES-CTR/GCM, FEC (row, staircase, 2D), Stream ID, and 80+ stats counters.',
    link: '/srt/overview/',
    color: 'amber',
  },
  {
    name: 'bilbycast-appear-x-api-gateway',
    description: 'Reference API gateway sidecar — bridges Appear X encoder/gateway platforms into the bilbycast manager via the same WebSocket protocol. Template for adding any third-party broadcast device.',
    link: '/appear-x-gateway/overview/',
    color: 'rose',
  },
];

const colorMap: Record<string, { ring: string; bg: string; text: string }> = {
  sky:     { ring: 'ring-sky-800/40',     bg: 'bg-sky-950',     text: 'text-sky-400' },
  violet:  { ring: 'ring-violet-800/40',  bg: 'bg-violet-950',  text: 'text-violet-400' },
  emerald: { ring: 'ring-emerald-800/40', bg: 'bg-emerald-950', text: 'text-emerald-400' },
  amber:   { ring: 'ring-amber-800/40',   bg: 'bg-amber-950',   text: 'text-amber-400' },
  rose:    { ring: 'ring-rose-800/40',    bg: 'bg-rose-950',    text: 'text-rose-400' },
};
---

<section id="products" class="py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">The Suite</h2>
      <p class="mt-4 text-lg text-slate-400">Five components that work together for complete media transport infrastructure.</p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {products.map((p) => {
        const c = colorMap[p.color];
        return (
          <a
            href={p.link}
            class="group rounded-xl border border-slate-800 bg-gradient-to-br from-slate-800/30 to-slate-900/10 p-6 transition hover:border-slate-700 hover:shadow-lg hover:shadow-black/20 no-underline"
          >
            <div class={`inline-flex items-center gap-2 rounded-full ${c.bg} ${c.ring} ring-1 px-3 py-1 text-xs font-semibold ${c.text}`}>
              {p.name}
            </div>
            <p class="mt-4 text-sm leading-relaxed text-slate-400">{p.description}</p>
            <span class={`mt-4 inline-flex items-center gap-1 text-sm font-medium ${c.text} group-hover:gap-2 transition-all`}>
              Learn more
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>
