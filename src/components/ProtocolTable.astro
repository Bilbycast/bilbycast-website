---
const protocols = [
  { name: 'SRT', input: true, output: true, features: 'AES-CTR/GCM, Stream ID, FEC, 2022-7 redundancy, SMPTE 302M audio mode, optional audio_encode + video_encode on TS output, optional delay block' },
  { name: 'RIST', input: true, output: true, features: 'VSF TR-06-1 Simple Profile — NACK-driven retransmit, SMPTE 2022-7 bonding, optional audio_encode + video_encode on TS output, optional delay block' },
  { name: 'RTP', input: true, output: true, features: 'SMPTE 2022-1 FEC, unicast/multicast, DSCP QoS, 2022-7 redundancy, optional audio_encode + video_encode on TS output, optional delay block' },
  { name: 'UDP', input: true, output: true, features: 'Raw MPEG-TS, unicast/multicast, SMPTE 302M audio mode, optional audio_encode + video_encode on TS output, optional delay block' },
  { name: 'RTMP/RTMPS', input: true, output: true, features: 'H.264 (FLV) + Enhanced-RTMP HEVC, AAC audio, ingest from OBS/ffmpeg, publish to Twitch/YouTube/Facebook, TLS, optional audio_encode + video_encode' },
  { name: 'RTSP', input: true, output: false, features: 'Pull H.264/H.265 from IP cameras, TCP/UDP' },
  { name: 'HLS', input: false, output: true, features: 'Segment-based egress, HEVC/HDR support, MPTS filtering, optional audio_encode (AAC/HE-AAC/MP2/AC-3)' },
  { name: 'WebRTC', input: true, output: true, features: 'WHIP/WHEP, H.264 + Opus, browser-compatible, via str0m, AAC→Opus and HEVC→H.264 auto-transcode' },
  { name: 'ST 2110-20', input: true, output: true, features: 'Uncompressed video (RFC 4175, YCbCr 4:2:2 8/10-bit), PTP, 2022-7 Red/Blue — bridged to H.264/HEVC compressed flows on egress' },
  { name: 'ST 2110-23', input: true, output: true, features: 'Uncompressed video partitioned (2SI + sample-row partition modes), PTP, 2022-7 Red/Blue' },
  { name: 'ST 2110-30', input: true, output: true, features: 'PCM L16/L24, AES67 / RFC 3190, PTP, 2022-7 Red/Blue, IS-08 channel routing + hot reload' },
  { name: 'ST 2110-31', input: true, output: true, features: 'AES3 transparent (Dolby E, Dolby Digital, etc.), bit-exact passthrough' },
  { name: 'ST 2110-40', input: true, output: true, features: 'RFC 8331 ancillary — SCTE-104, ATC timecode, CEA-608/708' },
  { name: 'rtp_audio', input: true, output: true, features: 'Generic RFC 3551 PCM over RTP (no PTP required), 302M-capable output, transcode + IS-08 channel mapping' },
  { name: 'Bonded', input: true, output: true, features: 'Carrier-grade multi-path aggregation — N heterogeneous paths over UDP / QUIC / RIST with media-aware IDR duplication across the two lowest-RTT legs, 32-bit ARQ, per-path RTT / loss / keepalive stats' },
];
---

<section id="protocols" class="py-24 lg:py-32 bg-slate-900/30">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Protocol Support</h2>
      <p class="mt-4 text-lg text-slate-400">A unified gateway for every common broadcast and streaming transport, with FEC and redundancy built in.</p>
      <p class="mt-3 text-sm text-slate-500">Compressed-audio bridge: AAC in MPEG-TS (carried over RTMP/RTSP/SRT/UDP/RTP) decodes in-process via Fraunhofer FDK AAC (AAC-LC, HE-AAC v1/v2, multichannel up to 7.1), and can be re-encoded to AAC-LC, HE-AAC v1/v2, Opus, MP2, or AC-3 — all in-process via FDK AAC or libavcodec — on any RTMP, HLS, WebRTC, SRT, UDP, RTP, or RIST output.</p>
      <p class="mt-3 text-sm text-slate-500">Video transcoding (<code class="text-slate-400">video_encode</code>): libx264, libx265, and NVIDIA NVENC targeting H.264/HEVC on SRT, RIST, UDP, RTP, RTMP, and WebRTC outputs (WebRTC is H.264-only; HEVC sources are auto-transcoded). Shipped in the <code class="text-slate-400">*-full</code> release channel; default <code class="text-slate-400">*-linux</code> binaries ship AGPL-only without software encoders.</p>
    </div>

    <div class="mt-12 overflow-hidden rounded-xl border border-slate-800 bg-slate-900/60">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-800 bg-slate-800/40">
            <th class="px-6 py-3.5 text-left font-semibold text-slate-300">Protocol</th>
            <th class="px-4 py-3.5 text-center font-semibold text-slate-300">Input</th>
            <th class="px-4 py-3.5 text-center font-semibold text-slate-300">Output</th>
            <th class="hidden px-6 py-3.5 text-left font-semibold text-slate-300 md:table-cell">Key Features</th>
          </tr>
        </thead>
        <tbody>
          {protocols.map((p, i) => (
            <tr class={`border-b border-slate-800/50 ${i % 2 === 0 ? 'bg-slate-900/30' : ''}`}>
              <td class="px-6 py-3.5 font-semibold text-white">{p.name}</td>
              <td class="px-4 py-3.5 text-center">
                {p.input ? (
                  <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/15 text-emerald-400">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </span>
                ) : (
                  <span class="text-slate-600">&mdash;</span>
                )}
              </td>
              <td class="px-4 py-3.5 text-center">
                {p.output ? (
                  <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-blue-500/15 text-blue-400">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </span>
                ) : (
                  <span class="text-slate-600">&mdash;</span>
                )}
              </td>
              <td class="hidden px-6 py-3.5 text-slate-400 md:table-cell">{p.features}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
