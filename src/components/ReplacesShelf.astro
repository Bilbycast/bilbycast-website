---
const appliances = [
  { label: 'Vendor dashboards', sub: 'one console per vendor' },
  { label: 'Transcode box', sub: 'AWS Elemental / ffmpeg farm' },
  { label: 'NMOS gateway', sub: 'IS-04 / 05 / 08 bridge' },
  { label: 'SRT / RIST gateway', sub: 'Zixi / Haivision' },
];
---

<section class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Replaces a rack of single-purpose appliances.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-400 sm:text-lg">
        Most live-media plants are still a stack of boxes — one for transcoding, one for the NMOS bridge, one for SRT,
        and a different vendor dashboard for each. Bilbycast collapses them into a single Rust suite that runs on
        commodity off-the-shelf hardware — 1U server, ARM appliance, or virtual machine.
      </p>
    </div>

    <!-- Visual -->
    <div class="mt-16">
      <div class="relative grid items-center gap-10 lg:grid-cols-[1fr_auto_1fr]">
        <!-- The shelf of appliances -->
        <div class="grid gap-3 sm:grid-cols-2">
          {appliances.map((a) => (
            <div class="group relative overflow-hidden rounded-lg border border-slate-800 bg-slate-900/40 p-5 opacity-70 transition hover:opacity-90">
              <!-- "Crossed out" diagonal line -->
              <div class="pointer-events-none absolute inset-0 opacity-50">
                <svg class="h-full w-full text-slate-600" preserveAspectRatio="none" viewBox="0 0 100 100">
                  <line x1="0" y1="100" x2="100" y2="0" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" />
                </svg>
              </div>
              <div class="relative">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded bg-slate-800 text-slate-500 ring-1 ring-slate-700">
                    <!-- Generic appliance / 1U server icon -->
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="6" width="18" height="5" rx="1" />
                      <rect x="3" y="13" width="18" height="5" rx="1" />
                      <circle cx="6" cy="8.5" r="0.5" fill="currentColor" />
                      <circle cx="6" cy="15.5" r="0.5" fill="currentColor" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-slate-300">{a.label}</div>
                    <div class="text-xs text-slate-500">{a.sub}</div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Arrow -->
        <div class="flex items-center justify-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-sky-950 text-sky-400 ring-1 ring-sky-800/40 lg:h-14 lg:w-14">
            <svg class="hidden h-5 w-5 lg:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            <svg class="h-5 w-5 lg:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>
        </div>

        <!-- The Bilbycast box -->
        <div class="relative">
          <div class="absolute -inset-2 rounded-xl bg-gradient-to-r from-sky-600/20 via-cyan-500/20 to-sky-600/20 blur-xl"></div>
          <div class="relative rounded-xl border border-sky-700/50 bg-gradient-to-br from-sky-950/80 to-slate-900/80 p-6 shadow-xl shadow-sky-950/40">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-none items-center justify-center rounded-lg bg-sky-600 text-white shadow-lg shadow-sky-600/30">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div class="min-w-0">
                <div class="text-xs font-semibold uppercase tracking-wider text-sky-400">One binary</div>
                <div class="mt-1 text-lg font-bold text-white">bilbycast-edge</div>
                <p class="mt-2 text-sm leading-relaxed text-slate-400">
                  Pure-Rust gateway. Bonding, transcoding, every protocol, NMOS, hitless redundancy, encryption — all in process.
                </p>
                <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-emerald-950/60 px-2.5 py-0.5 text-xs font-medium text-emerald-400 ring-1 ring-emerald-800/40">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                  AGPL 3 · Free
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
