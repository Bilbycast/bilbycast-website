---
import { Image } from 'astro:assets';
import topology from '../assets/screenshots/network-topology.png';
import flows from '../assets/screenshots/flows.png';
import edgeStatus from '../assets/screenshots/edge-status.png';
import aiConfig from '../assets/screenshots/ai-config.png';

const screenshots = [
  {
    image: topology,
    title: 'Network Topology',
    description: 'Live visual map of edge nodes, relay servers, and connections with protocol-aware routing.',
  },
  {
    image: flows,
    title: 'Flows Overview',
    description: 'Monitor all media flows across nodes with live thumbnails, bitrate, protocol badges, and health status.',
  },
  {
    image: edgeStatus,
    title: 'Node Detail',
    description: 'Deep dive into any node — live video preview, TR-101290 transport analysis, media codec detection, and fan-out topology.',
  },
  {
    image: aiConfig,
    title: 'AI Assistant',
    description: 'AI-powered flow configuration with context-aware recommendations. Supports OpenAI, Anthropic, and Gemini.',
  },
];
---

<section id="screenshots" class="py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">See It In Action</h2>
      <p class="mt-4 text-lg text-slate-400">A professional management interface built for broadcast operations.</p>
    </div>

    <div class="mt-16 grid gap-16 lg:gap-20">
      {screenshots.map((s, i) => (
        <div class={`flex flex-col gap-8 lg:flex-row lg:items-center lg:gap-12 ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <!-- Screenshot -->
          <div class="lg:w-3/5">
            <div class="overflow-hidden rounded-xl border border-slate-700/50 bg-slate-900 shadow-xl shadow-black/30">
              <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-2">
                <div class="flex gap-1.5">
                  <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                  <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                  <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                </div>
              </div>
              <Image
                src={s.image}
                alt={s.title}
                class="w-full h-auto"
                widths={[480, 720, 960]}
                sizes="(max-width: 768px) 480px, (max-width: 1024px) 720px, 960px"
              />
            </div>
          </div>
          <!-- Text -->
          <div class="lg:w-2/5">
            <h3 class="text-2xl font-bold text-white">{s.title}</h3>
            <p class="mt-3 text-base leading-relaxed text-slate-400">{s.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
