---
import { Image } from 'astro:assets';
import topology from '../assets/screenshots/network-topology.png';
import flows from '../assets/screenshots/flows.png';
import edgeStatus from '../assets/screenshots/edge-status.png';
import aiConfig from '../assets/screenshots/ai-config.png';
import managedNodes from '../assets/screenshots/managed-nodes.png';
import eventsAlarms from '../assets/screenshots/events-alarms.png';
import nodeBus from '../assets/screenshots/node-bus.png';
import switcher from '../assets/screenshots/switcher.png';
import replay from '../assets/screenshots/replay.png';
import auditLogs from '../assets/screenshots/audit-logs.png';
import servicesTemplates from '../assets/screenshots/services-templates.png';
import flowStatus from '../assets/screenshots/edge-flow-status.png';
import flowMediaStatus from '../assets/screenshots/edge-flow-media-status-counters.png';

const allSlides = {
  topology: {
    image: topology,
    title: 'Network Topology',
    description: 'Live visual map of edge nodes, relay servers, and connections with protocol-aware routing.',
  },
  flows: {
    image: flows,
    title: 'Flows Overview',
    description: 'Monitor every media flow across nodes — live thumbnails, bitrate, protocol badges, health status.',
  },
  'edge-status': {
    image: edgeStatus,
    title: 'Node Detail',
    description: 'Drill into any node — live video preview, TR-101290 transport analysis, codec detection, fan-out topology.',
  },
  'ai-config': {
    image: aiConfig,
    title: 'AI Assistant',
    description: 'AI-assisted flow configuration with context-aware recommendations. OpenAI, Anthropic, or Gemini.',
  },
  'managed-nodes': {
    image: managedNodes,
    title: 'Managed Nodes',
    description: 'Roster view across the full plant — health, version, capabilities, last-seen status at a glance.',
  },
  events: {
    image: eventsAlarms,
    title: 'Events & Alarms',
    description: 'Severity-graded operational events from every connected device with structured details and filters.',
  },
  'node-bus': {
    image: nodeBus,
    title: 'Node Bus Matrix',
    description: 'Three-pane crosspoint authoring — Sources, Crosspoint, Inspector. Click-to-wire or drag-and-drop programs across every output. Lawo-style pending state with atomic Apply.',
  },
  switcher: {
    image: switcher,
    title: 'Live Switcher',
    description: 'PGM/PVW director console with named profiles, per-page grouping, drift detection, and a one-click Take. Drives Bilbycast edges and third-party devices through the same driver-aware action system.',
  },
  replay: {
    image: replay,
    title: 'Replay',
    description: 'Per-flow JKL-scrub timeline with mark in/out, quick-clip last-N-seconds, sport-preset tag profiles, and a one-click Push-to-air per clip. No separate replay server, no separate licence.',
  },
  'audit-log': {
    image: auditLogs,
    title: 'Audit Log',
    description: 'Every operator action recorded with timestamp, user, target, and structured details. Filter by date, group, or action; complete tenant-scoped accountability for shared plants.',
  },
  services: {
    image: servicesTemplates,
    title: 'Services & Templates',
    description: 'Wizard-driven catalogue of transport templates — SRT, RIST, RTP, UDP, ST 2110, Appear X chassis — that turn complex multi-node setups into a single guided click.',
  },
  'flow-status': {
    image: flowStatus,
    title: 'Flow Signal Map',
    description: 'Per-flow fan-out view — every input, every output, live bitrate, and a thumbnail preview of the on-air content. Click any leg to dive into TR-101290, codec, and PCR analysis.',
  },
  'flow-media': {
    image: flowMediaStatus,
    title: 'In-depth Media Analysis',
    description: 'Per-flow loudness (R128 / Live momentary / true peak), audio + video PID counters, frame-rate, resolution, PCR_AC, and bitstream conformance — broadcast-grade diagnostics in the browser.',
  },
};

interface Props {
  slides?: (keyof typeof allSlides)[];
  heading?: string;
  subheading?: string;
  anchorId?: string;
}

const {
  slides = ['flows', 'topology', 'ai-config'],
  heading = 'See it in action',
  subheading = 'A management interface built for live broadcast operators, not for cloud admins.',
  anchorId = 'showcase',
} = Astro.props;

const screenshots = slides.map((key) => allSlides[key]).filter(Boolean);
---

<section id={anchorId} class="py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{heading}</h2>
      <p class="mt-4 text-lg text-slate-400">{subheading}</p>
    </div>

    <div class="mt-16 grid gap-16 lg:gap-20">
      {screenshots.map((s, i) => (
        <div class={`flex flex-col gap-8 lg:flex-row lg:items-center lg:gap-12 ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <div class="lg:w-3/5">
            <div class="overflow-hidden rounded-xl border border-slate-700/50 bg-slate-900 shadow-xl shadow-black/30">
              <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-2">
                <div class="flex gap-1.5">
                  <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                  <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                  <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                </div>
              </div>
              <Image
                src={s.image}
                alt={s.title}
                class="w-full h-auto"
                widths={[480, 720, 960]}
                sizes="(max-width: 768px) 480px, (max-width: 1024px) 720px, 960px"
              />
            </div>
          </div>
          <div class="lg:w-2/5">
            <h3 class="text-2xl font-bold text-white">{s.title}</h3>
            <p class="mt-3 text-base leading-relaxed text-slate-400">{s.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
