---
const items = [
  'SRT',
  'RIST',
  'SMPTE ST 2110',
  'SMPTE 2022-7',
  'NMOS IS-04 / 05 / 08',
  'TR-101290',
  'ChaCha20-Poly1305',
  'TLS 1.3 / QUIC',
];
---

<section aria-label="Standards and certifications" class="border-y border-slate-800/60 bg-slate-900/30 py-6">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-xs font-medium uppercase tracking-wider text-slate-500">
      <span class="text-slate-400">Built on broadcast standards</span>
      <span class="hidden h-3 w-px bg-slate-700 sm:block"></span>
      {items.map((item) => (
        <span class="whitespace-nowrap text-slate-500">{item}</span>
      ))}
    </div>
  </div>
</section>
