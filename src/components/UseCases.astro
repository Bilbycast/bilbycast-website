<section class="py-24 lg:py-32 bg-slate-900/30">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Use Cases</h2>
      <p class="mt-4 text-lg text-slate-400">From live events to cloud distribution — built for real broadcast workflows.</p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {useCases.map((u) => (
        <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-950 text-sky-400 ring-1 ring-sky-800/40">
            <Fragment set:html={u.icon} />
          </div>
          <h3 class="mt-4 text-lg font-semibold text-white">{u.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{u.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
