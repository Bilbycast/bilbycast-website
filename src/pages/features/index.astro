---
import Landing from '../../layouts/Landing.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const pillars = [
  {
    eyebrow: 'Pillar 1',
    title: 'Manager & AI',
    body: 'Real-time topology, AI-assisted flow creation, driver-aware control of Bilbycast and third-party broadcast devices. Multi-tenant Groups with brand theming, OIDC SSO, MFA, encrypted backup.',
    href: '/features/manager/',
    accent: 'sky',
  },
  {
    eyebrow: 'Pillar 2',
    title: 'One gateway, every format',
    body: 'Twelve protocols ingressed and egressed in one binary. In-process video and audio transcoding. NMOS-friendly. Replaces the transcode box and the protocol bridge.',
    href: '/features/one-gateway/',
    accent: 'sky',
  },
  {
    eyebrow: 'Pillar 3',
    title: 'Built for live sports',
    body: 'JKL-scrub Replay, sport-preset tag profiles, push-to-air, PGM/PVW Switcher, cron-scheduled Routines. Built for show-day workflow.',
    href: '/features/live-sports/',
    accent: 'sky',
  },
  {
    eyebrow: 'Pillar 4',
    title: 'Drops into your facility',
    body: 'NMOS IS-04 / 05 / 08 + BCP-004; SMPTE ST 2110-20/-23/-30/-31/-40 with PTP + 2022-7 Red/Blue; SMPTE 2022-1 FEC, TR-101290, RIST TR-06-1 / TR-07.',
    href: '/features/one-gateway/#standards',
    accent: 'sky',
  },
];
---

<Landing
  title="Bilbycast — Features"
  description="Four pillars of Bilbycast: the AI-assisted manager, the one-gateway protocol stack, the live-sports workflow, and broadcast-facility standards (NMOS, ST 2110, 2022-7). Each pillar links to a deep-dive feature page."
>
  <section class="pt-32 pb-12 lg:pt-40 lg:pb-16">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">Four pillars</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-400">
        Pick the pillar that matches your job. Each links to a deep-dive page with diagrams, bandwidth math, and screenshots.
        Looking for the full checkbox-by-checkbox feature list? <a href="/features/all/" class="text-sky-400 hover:text-sky-300">See every capability →</a>
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-6 md:grid-cols-2">
        {pillars.map((p) => (
          <a
            href={p.href}
            class="group flex flex-col rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-800/40 to-slate-900/20 p-8 transition hover:border-sky-800/60 hover:shadow-xl hover:shadow-sky-950/20 no-underline"
          >
            <div class="text-xs font-semibold uppercase tracking-wider text-sky-400">{p.eyebrow}</div>
            <h3 class="mt-3 text-2xl font-bold text-white">{p.title}</h3>
            <p class="mt-3 text-base leading-relaxed text-slate-400">{p.body}</p>
            <span class="mt-auto pt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-sky-400 group-hover:gap-2 transition-all">
              Read the deep dive
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Landing>
