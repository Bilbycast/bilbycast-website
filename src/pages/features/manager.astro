---
import { Image } from 'astro:assets';
import Landing from '../../layouts/Landing.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import topology from '../../assets/screenshots/network-topology.png';
import aiConfig from '../../assets/screenshots/ai-config.png';
import managedNodes from '../../assets/screenshots/managed-nodes.png';

const capabilities = [
  {
    title: 'Real-time topology',
    body: 'Live visual map of every edge, relay, and third-party device. Connections light up as data flows. Click any node for a deep-dive: live video preview, TR-101290 transport analysis, codec detection, fan-out topology.',
  },
  {
    title: 'AI-assisted flow creation',
    body: 'A built-in AI assistant understands your network topology and can create, analyze, and troubleshoot media flows via the driver-aware action system. Bring your own credentials for OpenAI, Anthropic, or Gemini — credentials are stripped before any LLM context.',
  },
  {
    title: 'Driver-aware control of third-party devices',
    body: 'A plugin architecture treats every device type — Bilbycast edge, relay, and third-party broadcast hardware — as a self-contained driver. Today: Bilbycast and Appear X. Tomorrow: whatever you build with the Gateway SDK.',
  },
  {
    title: 'Multi-tenant Groups with brand theming',
    body: 'Tenant-isolated users, resources, and quotas with per-tenant logo and brand-colour theming. White-label out of the box. Cross-tenant tunnels, share-cron, ownership transfer, per-tenant Switcher pages.',
  },
  {
    title: 'Routines — automate show-day workflows',
    body: 'Cron-scheduled named target states across flows. DST-correct via IANA timezones. Real-time fire-partial / fire-failed / missed events. One routine can cue 50 flows simultaneously.',
  },
  {
    title: 'Per-node "Open Device Web UI" link',
    body: 'Operators add a URL on the node row that opens the device\'s own admin UI in a new tab. The manager is not in the request path — point the URL at whatever port-forward, SSH tunnel, or LAN address reaches the device from your browser.',
  },
];

const security = [
  { label: 'TOTP MFA', body: 'pure-Rust totp-rs' },
  { label: 'OIDC SSO', body: 'optional, with tenant-aware group sync' },
  { label: 'Envelope encryption', body: 'per-secret DEK wrapped by domain-specific KEK; HKDF-SHA256' },
  { label: 'Master-key rotation', body: 'one-shot CLI; no service restart required' },
  { label: 'Per-IP + per-account login limits', body: '15-min lockout after 5 failed passwords' },
  { label: 'Encrypted backup & restore', body: 'portable export + DR-grade pg_dump archive (licensed)' },
];
---

<Landing
  title="Bilbycast — Manager & AI"
  description="The Bilbycast Manager: real-time topology, AI-assisted flow creation, driver-aware control of third-party broadcast devices, multi-tenant Groups with brand theming, OIDC SSO, MFA, encrypted backup, and envelope-encrypted secrets at rest."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-sky-950/30 via-[#020617] to-[#020617]"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] rounded-full bg-sky-600/8 blur-[120px]"></div>
    </div>

    <div class="mx-auto max-w-5xl px-6 text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-sky-800/40 bg-sky-950/40 px-4 py-1.5 text-xs font-medium text-sky-300">
        <span class="h-1.5 w-1.5 rounded-full bg-sky-400"></span>
        Pillar 4 · Manager &amp; AI
      </div>
      <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
        Manage your media plant
        <span class="block bg-gradient-to-r from-sky-400 to-cyan-300 bg-clip-text text-transparent">
          like software, not appliances.
        </span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-400 sm:text-xl">
        One control plane for Bilbycast and third-party broadcast devices. AI-assisted flow creation,
        real-time topology, multi-tenant Groups with brand theming. Free for up to 10 nodes.
      </p>
    </div>
  </section>

  <!-- Topology screenshot -->
  <section class="pb-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="relative">
        <div class="absolute -inset-4 rounded-2xl bg-gradient-to-r from-sky-600/10 via-cyan-500/10 to-sky-600/10 blur-2xl"></div>
        <div class="relative overflow-hidden rounded-xl border border-slate-700/50 bg-slate-900 shadow-2xl shadow-black/50">
          <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-2.5">
            <div class="flex gap-1.5">
              <div class="h-2.5 w-2.5 rounded-full bg-slate-600"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-slate-600"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-slate-600"></div>
            </div>
            <div class="ml-3 flex-1 rounded-md bg-slate-700/50 px-3 py-1 text-xs text-slate-500">
              manager.bilbycast.com / topology
            </div>
          </div>
          <Image
            src={topology}
            alt="Bilbycast Manager network topology view with edge nodes, relay servers, and live connections"
            class="w-full h-auto"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 640px, (max-width: 1024px) 960px, 1280px"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Capabilities</h2>
        <p class="mt-4 text-lg text-slate-400">Six things the manager does that vendor-specific dashboards don't.</p>
      </div>
      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {capabilities.map((c) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-6">
            <h3 class="text-lg font-semibold text-white">{c.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI assistant screenshot -->
  <section class="py-24 bg-slate-900/30 border-y border-slate-800/60">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <div class="text-xs font-semibold uppercase tracking-wider text-sky-400">AI assistant</div>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
            "Set up a 1080p H.264 SRT receive on edge-3 and fan out to YouTube and Twitch."
          </h2>
          <p class="mt-4 text-base leading-relaxed text-slate-400">
            The manager exposes its driver-aware action system to a built-in LLM assistant. Describe what you want
            in plain English, the assistant proposes a flow definition, and you commit it with one click.
            Bring your own provider — OpenAI, Anthropic, or Gemini — credentials never leave your tenant.
          </p>
          <ul class="mt-6 list-none space-y-2.5">
            <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-300">
              <svg class="mt-0.5 h-4 w-4 flex-none text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Knows your network topology and the live state of every device</span>
            </li>
            <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-300">
              <svg class="mt-0.5 h-4 w-4 flex-none text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Proposes flows, never executes — you commit the change</span>
            </li>
            <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-300">
              <svg class="mt-0.5 h-4 w-4 flex-none text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Stripped of credentials and tunnel keys before any LLM context</span>
            </li>
          </ul>
        </div>
        <div>
          <div class="overflow-hidden rounded-xl border border-slate-700/50 bg-slate-900 shadow-xl shadow-black/30">
            <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-2">
              <div class="flex gap-1.5">
                <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                <div class="h-2 w-2 rounded-full bg-slate-600"></div>
                <div class="h-2 w-2 rounded-full bg-slate-600"></div>
              </div>
            </div>
            <Image
              src={aiConfig}
              alt="Bilbycast Manager AI assistant configuration"
              class="w-full h-auto"
              widths={[480, 720, 960]}
              sizes="(max-width: 1024px) 720px, 960px"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Security stripe -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Security baseline</h2>
        <p class="mt-4 text-lg text-slate-400">No bolt-ons. Every install ships with the same security primitives.</p>
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {security.map((s) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-5">
            <div class="text-sm font-semibold text-white">{s.label}</div>
            <div class="mt-1 text-xs text-slate-500">{s.body}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Managed nodes screenshot -->
  <section class="pb-24 lg:pb-32">
    <div class="mx-auto max-w-6xl px-6">
      <div class="overflow-hidden rounded-xl border border-slate-700/50 bg-slate-900 shadow-xl shadow-black/30">
        <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-800/80 px-4 py-2">
          <div class="flex gap-1.5">
            <div class="h-2 w-2 rounded-full bg-slate-600"></div>
            <div class="h-2 w-2 rounded-full bg-slate-600"></div>
            <div class="h-2 w-2 rounded-full bg-slate-600"></div>
          </div>
        </div>
        <Image
          src={managedNodes}
          alt="Bilbycast Manager managed-nodes roster view"
          class="w-full h-auto"
          widths={[640, 960, 1280]}
          sizes="(max-width: 768px) 640px, (max-width: 1024px) 960px, 1280px"
        />
      </div>
      <p class="mt-4 text-center text-sm text-slate-500">
        Roster view across the full plant — health, version, capabilities, last-seen status.
      </p>
    </div>
  </section>

  <CtaBanner />
</Landing>
